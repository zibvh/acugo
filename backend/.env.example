# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/bixcart

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ─── Email (Brevo HTTP API) ───────────────────────────────────────────────────
# 1. Sign up at https://app.brevo.com (free: 300 emails/day)
# 2. Go to SMTP & API → API Keys → Generate a new API key
# 3. Go to Senders & Domains → Add & verify your sender email address
# 4. Set EMAIL_FROM to that verified sender address
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Bixcart" <you@yourdomain.com>

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=StrongPassword@123

# ─── Web Push ─────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@yourdomain.com

# ─── AI Moderation (Google Gemini — FREE) ────────────────────────────────────
# Free tier: 1,500 requests/day, 1M tokens/day — more than enough!
# Get your free key in 30 seconds: https://aistudio.google.com/app/apikey
# Leave blank to disable AI moderation
GEMINI_API_KEY=
