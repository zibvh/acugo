# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/plazza

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: set SMTP_USER to your Gmail address, SMTP_PASS to an App Password
#   (Google Account → Security → 2-Step Verification → App passwords)
# Resend.com: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_SECURE=true
# Brevo (Sendinblue): SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Plazza" <no-reply@plazza.ng>

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ─── Web Push ─────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@plazza.ng
